# Supabase — safe to expose to client (EXPO_PUBLIC_ prefix)
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Third-party API keys — server/Edge Function only, NEVER use EXPO_PUBLIC_ prefix
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Voice input config
VOICE_PARSE_MODEL=claude-haiku-4-5
VOICE_PARSE_MAX_TOKENS=300
VOICE_TRANSCRIPTION_MAX_SECONDS=120

# Daily digest config
DAILY_DIGEST_LOOKAHEAD_DAYS=3
